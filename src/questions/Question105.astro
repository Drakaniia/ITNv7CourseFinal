<div class="question-card" id="card-104" data-qid="104" data-type="single">
  <div class="card-header">
    <span class="q-number">Q 105</span>
    <span class="q-tag single">Single Choice</span>
  </div>
  <div class="card-body">
    <p class="question-text">
      What service is provided by DHCP?
    </p>
    <div class="options" id="opts-104">
      <button class="option-btn" data-idx="0">
        <span class="opt-indicator"></span>
        <span class="opt-letter">A</span>
        <span class="opt-text">Dynamically assigns IP addresses to end and intermediary devices.</span>
      </button>
      <button class="option-btn" data-idx="1">
        <span class="opt-indicator"></span>
        <span class="opt-letter">B</span>
        <span class="opt-text">Allows remote access to network devices and servers.</span>
      </button>
      <button class="option-btn" data-idx="2">
        <span class="opt-indicator"></span>
        <span class="opt-letter">C</span>
        <span class="opt-text">Uses encryption to provide secure remote access to network devices and servers.</span>
      </button>
      <button class="option-btn" data-idx="3">
        <span class="opt-indicator"></span>
        <span class="opt-letter">D</span>
        <span class="opt-text">An application that allows real-time chatting among remote users.</span>
      </button>
    </div>

    <div class="submit-wrap" style="display: none;">
      <button class="submit-btn" id="submit-104" disabled>Submit Answer</button>
