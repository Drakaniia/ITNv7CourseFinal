<!--
  --- Question 85 ---
  This component represents the eighty-fifth question in the quiz.
-->

<div class="question-card" id="card-84" data-qid="84" data-type="single">
  <div class="card-header">
    <span class="q-number">Q 85</span>
    <span class="q-tag single">Single Choice</span>
  </div>
  <div class="card-body">
    <p class="question-text">
      A client packet is received by a server. The packet has a destination port number of 80. What service is the client requesting?
    </p>
    <div class="options" id="opts-84">
      <button class="option-btn" data-idx="0">
        <span class="opt-indicator"></span>
        <span class="opt-letter">A</span>
        <span class="opt-text">DNS</span>
      </button>
      <button class="option-btn" data-idx="1">
        <span class="opt-indicator"></span>
        <span class="opt-letter">B</span>
        <span class="opt-text">HTTP</span>
      </button>
      <button class="option-btn" data-idx="2">
        <span class="opt-indicator"></span>
        <span class="opt-letter">C</span>
        <span class="opt-text">DHCP</span>
      </button>
      <button class="option-btn" data-idx="3">
        <span class="opt-indicator"></span>
        <span class="opt-letter">D</span>
        <span class="opt-text">SMTP</span>
      </button>
    </div>

    <div class="submit-wrap" style="display: none;">
      <button class="submit-btn" id="submit-84" disabled>Submit Answer</button>
    </div>

    <div class="explanation" id="exp-84">
      <div class="exp-header">
        <span class="exp-verdict" id="verdict-84"></span>
      </div>
      <div class="exp-body">
        The client is requesting the HTTP (Hypertext Transfer Protocol) service. Port 80 is the standard port for HTTP, which is used for transmitting web pages on the internet.
      </div>
    </div>
    <div class="pagination-controls">
      <button class="nav-btn" id="prev-84">Previous</button>
      <span class="page-indicator">85 / 90</span>
      <button class="nav-btn" id="next-84">Next</button>
    </div>
  </div>
</div>
